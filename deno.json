{
  "tasks": {
    "dev": "deno run -A --watch --env-file=.env app/server.ts",
    "start": "deno run -A --env-file=.env app/server.ts",
    "dev:control": "deno run -A --watch --env-file=.env apps/control/server.ts",
    "dev:agent": "deno run -A --watch --env-file=.env apps/agent/server.ts",
    "start:control": "deno run -A --env-file=.env apps/control/server.ts",
    "start:agent": "deno run -A --env-file=.env apps/agent/server.ts",
    "test": "deno test -A --env-file=.env \"app/**/*.test.ts\"",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:migrate": "deno run -A --env-file=.env app/db/migrate.ts",
    "db:push": "deno run -A npm:drizzle-kit push",
    "db:studio": "deno run -A npm:drizzle-kit studio",
    "db:seed": "deno run -A --env-file=.env app/db/seed.ts",
    "load-test": "deno run -A --env-file=.env app/scripts/load-test.ts",
    "auto-rollback": "deno run -A --env-file=.env app/scripts/auto-rollback.ts",
    "verify-auto-rollback": "deno run -A --env-file=.env app/scripts/verify-auto-rollback.ts",
    "reencrypt-secrets": "deno run -A --env-file=.env app/scripts/reencrypt-secrets.ts"
  },
  "imports": {
    "~/": "./app/",
    "@hono/hono": "jsr:@hono/hono@^4",
    "@hono/node-server": "npm:@hono/node-server@^2",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "plist": "npm:plist@3",
    "node-forge": "npm:node-forge@1"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto"
}
