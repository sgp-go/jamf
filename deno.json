{
  "tasks": {
    "dev": "deno run -A --watch --env-file=.env app/server.ts",
    "start": "deno run -A --env-file=.env app/server.ts",
    "test": "deno test -A --env-file=.env \"app/**/*.test.ts\"",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:migrate": "deno run -A --env-file=.env app/db/migrate.ts",
    "db:push": "deno run -A npm:drizzle-kit push",
    "db:studio": "deno run -A npm:drizzle-kit studio",
    "db:seed": "deno run -A --env-file=.env app/db/seed.ts",
    "load-test": "deno run -A --env-file=.env app/scripts/load-test.ts",
    "src:dev": "deno run --unstable-http --allow-env --allow-read --allow-write --allow-net --allow-ffi --watch src/server.ts",
    "src:start": "deno run --unstable-http --allow-env --allow-read --allow-write --allow-net --allow-ffi src/server.ts",
    "src:test-api": "deno run --allow-env --allow-read --allow-net src/scripts/test-api.ts"
  },
  "imports": {
    "~/": "./app/",
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "plist": "npm:plist@3",
    "node-forge": "npm:node-forge@1"
  },
  "compilerOptions": {
    "strict": true
  },
  "nodeModulesDir": "auto"
}
