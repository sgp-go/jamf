# ===== 產品化版本（app/）所需 =====
# Postgres 連線（多租戶後端唯一資料來源）
DATABASE_URL=postgres://jamf_explore:dev@localhost:5432/jamf_explore_dev
PORT=3000
NODE_ENV=development

# 機密加密金鑰（base64, 32 bytes）— Phase 3 才啟用
# DATA_ENCRYPTION_KEY=

# Admin API 的 Bearer token（管理 tenant / jamf instance CRUD）。
# 未設則 /api/v1/admin/* 全部回 503 admin_token_not_configured（安全預設，不裸奔）。
ADMIN_API_TOKEN=change-me-to-a-long-random-string

# ===== 以下為舊版 src/ 的單租戶 PoC 配置（凍結，僅供對照） =====
# Jamf Pro API Configuration
# Instance: cogrow.jamfcloud.com

JAMF_BASE_URL=https://your-instance.jamfcloud.com

# Client Credentials (推薦使用此方式認證)
JAMF_CLIENT_ID=your-client-id
JAMF_CLIENT_SECRET=your-client-secret

# Local Admin Account (備用認證方式)
JAMF_API_USERNAME=api_admin
JAMF_API_PASSWORD=your-password

# App Lock Static Group ID（Profile scope 綁定到此群組，API 透過增減群組成員控制開關）
JAMF_APP_LOCK_GROUP_ID=

# 自建 MDM（ngrok URL，每次啟動後更新）
MDM_SERVER_URL=https://xxxx.ngrok-free.app
# 憑證透過 API 上傳，無需手動設定：
#   APNS 推播憑證: POST /api/mdm/certs/apns（自動提取 topic）
#   DEP Token:     POST /api/mdm/dep/token
#   CA 憑證:       自動生成，或 POST /api/mdm/certs/ca/regenerate

# ---- WNS 推播（Windows MDM）----
# 申請流程見 docs/windows-mdm-account-setup.md
WNS_PACKAGE_SID=ms-app://S-1-15-2-...
WNS_CLIENT_SECRET=
WNS_PFN=YourPublisher.YourAppName_xxxxxxxxxxxxx
WNS_STORE_PRODUCT_ID=
