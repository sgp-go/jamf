# Jamf Pro API Configuration
# Instance: cogrow.jamfcloud.com

JAMF_BASE_URL=https://your-instance.jamfcloud.com

# Client Credentials (推薦使用此方式認證)
JAMF_CLIENT_ID=your-client-id
JAMF_CLIENT_SECRET=your-client-secret

# Local Admin Account (備用認證方式)
JAMF_API_USERNAME=api_admin
JAMF_API_PASSWORD=your-password

# App Lock Static Group ID（Profile scope 綁定到此群組，API 透過增減群組成員控制開關）
JAMF_APP_LOCK_GROUP_ID=
