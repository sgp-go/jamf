{
  "name": "jamf-explore-server",
  "version": "0.2.0-alpha",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env app/server.ts",
    "start": "node --env-file-if-exists=.env --import tsx app/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'app/**/*.test.ts'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env app/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file-if-exists=.env app/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.3",
    "@scalar/hono-api-reference": "^0.5.172",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.15",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
